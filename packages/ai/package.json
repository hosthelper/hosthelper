{
  "name": "@hosthelper/ai",
  "version": "0.1.0",
  "private": false,
  "description": "hosthelper AI 게이트웨이. Anthropic Claude SDK 래퍼 + 토큰 예산 가드레일. M&A 분리 가능.",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
