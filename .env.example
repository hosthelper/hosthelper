NODE_ENV=development

# Database
DATABASE_URL=postgresql://hosthelper:hosthelper@localhost:5432/hosthelper?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=4000
API_BASE_URL=http://localhost:4000
JWT_SECRET=replace-me-with-secret
JWT_EXPIRES_IN=7d

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# AWS
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=hosthelper-uploads-dev

# Payment (토스페이먼츠)
TOSS_CLIENT_KEY=test_ck_xxx
TOSS_SECRET_KEY=test_sk_xxx

# Notification (NHN 알림톡)
NHN_APP_KEY=
NHN_SECRET_KEY=
NHN_SENDER_KEY=

# Twilio (SMS fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# AI 게이트웨이 (Anthropic Claude)
ANTHROPIC_API_KEY=
HOSTHELPER_AI_MODEL=claude-opus-4-7
HOSTHELPER_AI_DAILY_BUDGET_USD=50

# 영상 음성 인식(STT) — 인스타/틱톡 등 자막 없는 영상 분석에 필요.
# 서버에 yt-dlp, ffmpeg, whisper 바이너리가 설치되어 있어야 동작. 서버리스 불가.
HOSTHELPER_STT_ENABLED=0
HOSTHELPER_YTDLP_BIN=yt-dlp
HOSTHELPER_FFMPEG_BIN=ffmpeg
HOSTHELPER_WHISPER_BIN=whisper
HOSTHELPER_WHISPER_MODEL=base
HOSTHELPER_STT_MAX_SEC=900
HOSTHELPER_STT_TIMEOUT_MS=300000
